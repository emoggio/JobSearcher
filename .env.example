# ── Claude API ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Job board APIs (optional — scrapers still work without these) ────────────
REED_API_KEY=
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///scout.db

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SCOUT_SECRET_KEY=change-me-use-a-long-random-string

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
SCOUT_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
